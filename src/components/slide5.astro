<section id="slide05" class="slide">
    <div class="gr2">
        <div class="elGrid">
            <div class="container2 left">
                <div class="group title">
                    <h2 class="h2 tGradient">Мобильное приложение</h2>
                    <p class="t20 grey">
                        Полный цикл разработки мобильного приложения под iOS и Android под ключ:
                    </p>
                </div>
                <div class="group">
                    <h3 class="t30">Что предлагаем:</h3>
                    <ul class="ulSin">
                        <li>Современный конверсионный UI/UX-дизайн</li>
                        <li>
                           Кросс-платформенная (Flutter / React Native) или нативная разработка
                        </li>
                        <li>
                          Backend, API-интеграции и сложная бизнес-логика
                        </li>
                        <li>
                          Push-уведомления, аналитика, платежи и другие функции
                        </li>
                        <li>
                            Полное тестирование и публикация в App Store / Google Play
                        </li>
                    </ul>
                </div>
                <div class="group">
                    <h3 class="t30">Для чего это вам:</h3>
                   <p class="t20 ">
                        Получить современное, быстрое и удобное приложение, которое привлечёт и удержит клиентов, повысит продажи и автоматизирует бизнес-процессы.
                    </p>
                </div>
                <div class="group">
                    <h3 class="t30">Результат:</h3>
                   <p class="t20 ">
                       Готовое приложение, соответствующее всем стандартам, которое уже в ближайшее время даст рост установок, конверсии и дохода вашего бизнеса.
                    </p>
                </div>

                <div class="bottom">
                    <div class="group info">
                        <p class="t16 grey">Сроки:</p>
                        <span class="t20 siniy"> от 20 дней </span>
                    </div>
                    <div class="group info">
                        <p class="t16 grey">Стоимость:</p>
                        <span class="t20 siniy"> от 200 000 ₽</span>
                    </div>

                    <div class="group  fosBox">
                        <p
                            style="font-style: italic; color:var(--siniy)"
                            class="t20"
                        >
                            <span>
                                Бесплатный дизайн главного экрана приложения</span
                            >
                        </p>
                        <button
                            class="but"
                            data-popup
                            data-popup-title="Бесплатный дизайн главного экрана приложения"
                        >
                            <b>Получить</b> бесплатно
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="elGrid right">
            <img
                class="composits"
                src="/img/5.png"
                alt="Мобильное приложение"
            />
        </div>
    </div>
</section>

<style>
    /* Базовые стили (десктоп) */
    .info {
        gap: 12px;
    }

    .title {
        margin-bottom: 0.5rem;
    }

    .bottom {
        display: flex;
        gap: 2rem;
        align-items: center;
        margin-top: auto;
    }

    .elGrid {
        width: 100%;
        height: 100%;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        gap: 2vh;
    }

    .right {
        background: url(/img/fon02.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .right .composits {
        width: 100%;
        object-fit: contain;
    }

    /* Убедитесь, что gr2 — это grid */
    .gr2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100%;
    }

    /* ===== АДАПТАЦИЯ ===== */

    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
        

        .title {
            margin-bottom: 32px;
        }

        .left {
            gap: 28px;
        }

      
    }

    /* Мобильные (до 768px) */
    @media (max-width: 768px) {
        .gr2 {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .left {
            gap: 24px;
        }

        .title {
            margin-bottom: 20px;
        }

        .bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            margin-top: 24px;
        }

        .info {
            gap: 8px;
            flex-direction: row;
            align-items: baseline;
        }
        .title {
            height: 80vh;
            background: url(/img/mob/5.png);
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            padding: 16px;
        }

        .title * {
            color: white !important;

            -webkit-text-fill-color: aliceblue;
        }

        .right {
            display: none;
        }
    }

    /* Маленькие телефоны (до 480px) */
    @media (max-width: 480px) {
        .container2 {
            padding: 0;
        }

        .group {
            padding: 1rem;
        }
        .title {
            margin-bottom: 16px;
            padding-top: 90px;
        }
        .left {
            gap: 10px;
        }

        .ulSin {
            padding-left: 20px;
        }

        .ulSin li {
            margin-bottom: 8px;
        }

        .bottom {
            width: 100%;
        }

        .info {
            width: 100%;
            justify-content: space-between;
        }

        .slide {
            padding-bottom: 60px;
        }
    }
</style>
