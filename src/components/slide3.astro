---
import Ic1 from "../assets/services/7.svg";
import Ic2 from "../assets/services/6.svg";
import Ic3 from "../assets/services/5.svg";
import Ic4 from "../assets/services/3.svg";
import Ic5 from "../assets/services/1.svg";
import Ic6 from "../assets/services/2.svg";
import Ic7 from "../assets/services/4.svg";
---

<section id="slide03" class="slide">
    <div class="container2">
        <h2 class="h2">Наши услуги</h2>
        <div class="content">
            <div
                class="item"
                style="--colS:1; --colEnd:2; --rowS:1; --rowEnd:2;"
            >
                <div class="group">
                    <h3 class="t28">Умные чат-боты</h3>
                    <p class="t16 grey">
                        Внедряем умных чат-ботов на базе ИИ, которые ведут
                        диалог, собирают заявки, консультируют клиентов и
                        экономят до 30 % бюджета
                    </p>
                </div>

                <div class="group ">
                    <div class="group g2">
                        <p class="t16">Сроки:</p>
                        <span class="t25 siniy"> от 2 дней </span>
                    </div>
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy"> от 20 000 ₽ </span>
                    </div>
                </div>
                <div class="decor">
                    <Ic1 class={"decor_img"} />
                </div>
            </div>

            <div
                class="item"
                style="--colS:3; --colEnd:2; --rowS:1; --rowEnd:1;"
            >
                <div class="group">
                    <h3 class="t28">Мобильное приложение</h3>
                </div>

                <div class="group row">
                    <div class="group g2">
                        <p class="t16">Сроки:</p>
                        <span class="t25 siniy">от 20 дней</span>
                    </div>
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy"> от 200 000 ₽ </span>
                    </div>
                </div>

                <div class="decor">
                    <Ic2 class={"decor_img"} />
                </div>
            </div>
            <div
                class="item glav"
                style="--colS:3; --colEnd:2; --rowS:2; --rowEnd:1;"
            >
                <div class="group">
                    <h3 class="h2">Аудит</h3>
                    <p class="t30">вашего сайта</p>

                    <p class="t28 pric">Бесплатно</p>
                </div>
            </div>
            <div
                class="item"
                style="--colS:5; --colEnd:2; --rowS:1; --rowEnd:2;"
            >
                <div class="group">
                    <h3 class="t28">Политика сайта</h3>
                    <p class="t16 grey">
                        Проводим полную юридическую проверку и настройку
                        политики сайта: защита данных, ФЗ-152, оферта и
                        соответствие всем требованиям закона
                    </p>
                </div>

                <div class="group">
                    <div class="group g2">
                        <p class="t16">Сроки:</p>
                        <span class="t25 siniy">от 2 дней </span>
                    </div>
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy"> от 15 000 ₽</span>
                    </div>
                </div>
                <div class="decor">
                    <Ic3 class={"decor_img"} />
                </div>
            </div>
        </div>
        <div class="content2">
            <div
                class="item"
                style="--colS:1; --colEnd:1; --rowS:1; --rowEnd:1;"
            >
                <div class="group">
                    <h3 class="t28">Разработка сайта</h3>
                </div>

                <div class="group row">
                    <div class="group g2">
                        <p class="t16">Сроки:</p>
                        <span class="t25 siniy"> от 7 дней </span>
                    </div>
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy">от 30 000 ₽ </span>
                    </div>
                </div>
                <div class="decor">
                    <Ic4 class={"decor_img"} />
                </div>
            </div>

            <div
                class="item"
                style="--colS:2; --colEnd:1; --rowS:1; --rowEnd:1;"
            >
                <div class="group">
                    <h3 class="t28">техническая поддержка</h3>
                </div>

                <div class="group">
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy">от 5 000 ₽</span>
                    </div>
                </div>
                <div class="decor">
                    <Ic5 class={"decor_img"} />
                </div>
            </div>

            <div
                class="item"
                style="--colS:3; --colEnd:1; --rowS:1; --rowEnd:1;"
            >
                <div class="group">
                    <h3 class="t28">Внедрение ИИ</h3>
                </div>

                <div class="group">
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy">от 50 000 ₽ </span>
                    </div>
                </div>
                <div class="decor">
                    <Ic6 class={"decor_img"} />
                </div>
            </div>
            <div
                class="item"
                style="--colS:4; --colEnd:1; --rowS:1; --rowEnd:1;"
            >
                <div class="group">
                    <h3 class="t28">разработка mini app</h3>
                </div>

                <div class="group">
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy">от 100 000 ₽ </span>
                    </div>
                </div>
                <div class="decor">
                    <Ic7 class={"decor_img"} />
                </div>
            </div>
        </div>
    </div>
</section>

<style>

    .row{
        flex-direction: row;
        gap: 1rem;
    }
    .content {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: repeat(2, 200px);
        gap: 20px;
        margin-top: 30px;
    }
    

    .content2 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(1, 200px);
        gap: 20px;
        margin-top: 20px;
    }

    .g2 {
        gap: 0;
    }

    .item {
        border-radius: var(--br);
        background: var(--belyy);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 20px;
        position: relative;
        overflow: hidden;
        padding: 30px 25px;
        grid-column: var(--colS) / span var(--colEnd);
        grid-row: var(--rowS) / span var(--rowEnd);
    }

    .item * {
        z-index: 3;
        position: relative;
    }

    .decor {
        position: absolute !important;
        right: -4%;
        bottom: -10%;
        width: auto;
        height: 70%;
        z-index: 1 !important;
    }

    .decor_img {
        width: 100%;
        height: 100%;
        z-index: 1;
        object-fit: contain;
    }

    .glav {
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: url(/img/fon03.jpg);
        background-size: cover;
        background-position: center center;
    }

    .item:not(:hover) :global(.elSvgPath) {
        transition: 300ms;
        fill: transparent;
        stroke: #a5a5a521;
        stroke-width: 0.5;
    }

    .glav * {
        color: var(--belyy) !important;
        text-align: center;
    }

    .pric {
        text-transform: none;
        position: relative;
    }

    .pric::after,
    .pric::before {
        content: "";
        background: var(--belyy);
        height: 2px;
        width: 200px;
        position: absolute;
    }

    .pric::after {
        right: -70%;
        top: 50%;
    }

    .pric::before {
        left: -70%;
        top: 50%;
    }

    /* Адаптация для мобильных устройств */
    @media (max-width: 768px) {
        .item:not(:hover) :global(.elSvgPath) {
            fill: revert-layer;
            stroke: transparent;
        }

        .h2 {
            width: 100%;
        }
        .content {
            grid-template-columns: 1fr !important;
            grid-template-rows: auto !important;
            gap: 15px;
        }

        .content2 {
            grid-template-columns: 1fr !important;
            grid-template-rows: auto !important;
            gap: 15px;
        }

        .item {
            grid-column: auto !important;
            grid-row: auto !important;
            padding: 20px 15px;
            min-height: 180px;
        }

        .decor {
            right: -2%;
            bottom: -5%;
            height: 60%;
            opacity: 0.7;
        }

        .glav {
            min-height: 200px;
        }

        .pric::after,
        .pric::before {
            width: 50px;
        }

        .pric::after {
            right: -60%;
        }

        .pric::before {
            left: -60%;
        }

        .t28 {
            font-size: 20px;
        }

        .t25 {
            font-size: 18px;
        }

        .t16 {
            font-size: 14px;
        }

        .group {
            gap: 1vh;
        }

        .g2 {
            flex-wrap: wrap;
        }
    }

    /* Для очень маленьких экранов */
    @media (max-width: 480px) {
        .slide {
            padding-top: 60px;
        }
        .item {
            padding: 15px 12px;
            min-height: 160px;
        }

        .decor {
            height: 50%;
        }

        .t28 {
            font-size: 18px;
        }

        .t25 {
            font-size: 16px;
        }

        .t16 {
            font-size: 13px;
        }

        .pric::after,
        .pric::before {
            width: 30px;
        }
    }
</style>
