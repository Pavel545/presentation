<style>
    .row {
        flex-direction: row;
        gap: 1rem;
    }
    .content {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: repeat(2, 20vh);
        gap: 20px;
        margin-top: 30px;
    }

    .content2 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(1, 20vh);
        gap: 20px;
        margin-top: 20px;
    }

    .isMobile {
        display: none;
    }

    .g2 {
        gap: 0;
            margin-top: auto;

    }
    .h2 {
        width: 100%;
    }
    .item {
        border-radius: var(--br);
        background: var(--belyy);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 2vh;
        position: relative;
        overflow: hidden;
        padding: 30px 25px;
        grid-column: var(--colS) / span var(--colEnd);
        grid-row: var(--rowS) / span var(--rowEnd);

        cursor: pointer;
    }

    .item * {
        z-index: 3;
        position: relative;
    }

    .decor {
        position: absolute !important;
        right: -4%;
        bottom: -10%;
        width: auto;
        height: 70%;
        z-index: 1 !important;
    }

    .decor_img {
        width: 100%;
        height: 100%;
        z-index: 1;
        object-fit: contain;
    }

    .glav {
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
        overflow: hidden;
    }

    .item:not(:hover) :global(.elSvgPath) {
        transition: 300ms;
        fill: transparent;
        stroke: #a5a5a521;
        stroke-width: 0.5;
    }

    .glav * {
        color: var(--belyy) !important;
        text-align: center;
    }

    .pric {
        text-transform: none;
        position: relative;
    }

    .pric::after,
    .pric::before {
        content: "";
        background: var(--belyy);
        height: 2px;
        width: 200px;
        z-index: 9;
        position: absolute;
    }

    .pric::after {
        right: -70%;
        top: 50%;
    }

    .pric::before {
        left: -70%;
        top: 50%;
    }

    .bg-video {
        position: absolute !important;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Адаптация для мобильных устройств */
    @media (max-width: 768px) {
        .item:not(:hover) :global(.elSvgPath) {
            fill: revert-layer;
            stroke: transparent;
        }
        .isMobile {
            display: block;
        }
        .content {
            display: flex;
            flex-direction: column;
        }
        .glav {
            order: -1;
        }

        .content2 {
            grid-template-columns: 1fr !important;
            grid-template-rows: auto !important;
            gap: 15px;
        }

        .item {
            grid-column: auto !important;
            grid-row: auto !important;
            padding: 20px 15px;
            min-height: 180px;
        }

        .decor {
            right: -2%;
            bottom: -5%;
            height: 60%;
            opacity: 0.7;
        }

        .glav {
            min-height: 200px;
        }

        .pric::after {
            right: -60%;
        }

        .pric::before {
            left: -60%;
        }

     

        .group {
            gap: 1vh;
        }

        .g2 {
            flex-wrap: wrap;
        }
    }

    /* Для очень маленьких экранов */
    @media (max-width: 480px) {
        .slide {
            padding-top: 75px;
        }
        .item {
            padding: 15px 12px;
            min-height: 160px;
        }

        .decor {
            height: 50%;
        }

   

        .pric::after,
        .pric::before {
            width: 150px;
        }
    }
</style>

<script>
    const video = document.querySelector<HTMLVideoElement>(".bg-video");

    if (video) {
        let rafId: number | null = null;
        let lastTime = 0;

        // ограничиваем частоту обновлений (например ~30fps)
        const FRAME = 1000 / 30;
        let acc = 0;

        const playReverse = () => {
            if (rafId !== null) cancelAnimationFrame(rafId);

            lastTime = performance.now();
            acc = 0;

            const step = (now: number) => {
                const deltaMs = now - lastTime;
                lastTime = now;
                acc += deltaMs;

                if (acc >= FRAME) {
                    const delta = acc / 1000;
                    acc = 0;

                    video.currentTime -= delta * 0.7; // чуть медленнее = стабильнее
                }

                if (video.currentTime <= 0) {
                    video.currentTime = 0;
                    video.play();
                    return;
                }

                rafId = requestAnimationFrame(step);
            };

            rafId = requestAnimationFrame(step);
        };

        video.addEventListener("ended", () => {
            video.pause();
            playReverse();
        });

        video.addEventListener("play", () => {
            if (rafId !== null) cancelAnimationFrame(rafId);
        });
    }
</script>
