                </div>

                <div class="group">
                    <div class="group g2">
                        <p class="t16">Сроки:</p>
                        <span class="t25 siniy">от 2 дней </span>
                    </div>
                    <div class="group g2">
                        <p class="t16">Стоимость:</p>
                        <span class="t25 siniy"> от 15&nbsp;000&nbsp;₽</span>
