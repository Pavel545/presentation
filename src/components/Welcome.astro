<section class="welcome slide " id="welcome">
    <div class="container">
        <div class="content">
            <h1 class="h1">
                Разработка <br />цифровых решений
            </h1>
            <p class="hPs">Для роста Вашего бизнеса</p>

            <div class="servicesList">
                <div class="servicesItem">Разработка сайта</div>
                                <div class="servicesItem">Чат-боты</div>

                <div class="servicesItem">Внедрение ИИ</div>

                <div class="servicesItem">Мобильное приложение</div>

                <div class="servicesItem">Дизайн</div>

            </div>
           
        </div>
    </div>
</section>

<style>
    .welcome {
        background: url(/fonHero.jpg);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }
    .content {
        display: flex;
        flex-direction: column;
        align-items: start;
        justify-content: center;
        height: 100vh;
    }
    .hPs {
        font-weight: 400;
        font-size: 40px;
        color: #bce0ff;
        opacity: 0.7;
        margin-top: 20px;
    }

    .servicesList {
        display: flex;
        flex-wrap: wrap;

        gap: 10px;
        margin-top: 115px;
        width: 100%;
        max-width: 800px;
    }

    .servicesItem {
        display: flex;
        align-items: center;
        gap: 10px;

        font-weight: 500;
        font-size: 25px;
        line-height: 110%;
        color: var(--belyy);
        position: relative;
        overflow: hidden;
        border-radius: 5px;
        padding: 10px 30px;

        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }
    .servicesItem::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.4) 0%,
            rgba(255, 255, 255, 0.1) 50%,
            rgba(255, 255, 255, 0.4) 100%
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
    }

    .servicesItem::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 50px;
        background: var(--zelenyy-2-osnovnoy);
    }
</style>
