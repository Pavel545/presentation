<section class="welcome slide" id="welcome">
    <div class="container">
        <div class="content">
            <h1 class="h1">
                Разработка <br />цифровых решений
            </h1>
            <p class="hPs">Для роста Вашего бизнеса</p>

            <div class="servicesList">
                <div data-id="7" class="servicesItem">Умные чат-боты</div>
                <div data-id="3" class="servicesItem">Аудит</div>
                <div data-id="8" class="servicesItem">Мобильное приложение</div>
                <div data-id="12" class="servicesItem">Политика сайта</div>
                <div data-id="4" class="servicesItem">Разработка сайта</div>
                <div data-id="13" class="servicesItem">
                    Техническая поддержка
                </div>
                <div data-id="11" class="servicesItem">Внедрение ИИ</div>
                <div data-id="9" class="servicesItem">Разработка Mini APP</div>
            </div>

            <div class="butt_box">
                <a class="butt2" target="_blank" href="/АЦР.pdf">
                    Скачать презентацию
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .welcome {
        background: url(/fonHero.jpg);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .butt_box {
        display: flex;
        gap: 20px;

        margin-top: 1.7rem;
    }

    .butt2 {
        background: var(--belyy);
        border-radius: 5px;
        padding: 19px 40px;

        font-weight: 500;
        font-size: 16px;
        line-height: 110%;
        text-transform: uppercase;
        color: var(--temnyy);

        transition: 300ms;
    }

    .butt2:hover {
        background: var(--zelenyy-2-osnovnoy);
    }

    .content {
        display: flex;
        flex-direction: column;
        align-items: start;
        justify-content: center;
        height: 100vh;
        padding: 0 20px;
    }

    .h1 {
        font-size: clamp(36px, 8vw, 8vh);
        line-height: 1.1;
    }

    .hPs {
        font-weight: 400;
        font-size: 4vh;
        color: #bce0ff;
        opacity: 0.7;
        margin-top: 20px;
    }

    .servicesList {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 115px;
        width: 100%;
        max-width: 900px;
        cursor: pointer;
        transition: 500ms;
    }

    .servicesItem {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
        font-size: 25px;
        line-height: 110%;
        color: var(--belyy);
        position: relative;
        overflow: hidden;
        border-radius: 5px;
        padding: 10px 30px;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }

    .servicesItem:hover {
        background: rgb(255 255 255 / 19%);
    }

    .servicesItem::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(
            332deg,
            rgba(255, 255, 255, 0.4) 0%,
            rgba(255, 255, 255, 0.1) 50%,
            rgba(255, 255, 255, 0.4) 100%
        );
        -webkit-mask:
            linear-gradient(#ffffff43 0 0) content-box,
            linear-gradient(#ffffff56 0 0);
        mask:
            linear-gradient(#ffffff47 0 0) content-box,
            linear-gradient(#ffffff2b 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
    }

    .servicesItem::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 50px;
        background: var(--zelenyy-2-osnovnoy);
    }

    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
        .hPs {
            font-size: 32px;
        }

        .servicesList {
            margin-top: 80px;
            max-width: 700px;
        }

        .servicesItem {
            font-size: 22px;
            padding: 8px 24px;
        }
    }

    /* Мобильные устройства (до 768px) */
    @media (max-width: 768px) {
        .welcome {
            background: url(/fonHeroMob.jpg);
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            padding: 0;
        }

        .content {
            height: auto;
            min-height: 100vh;
            padding: 100px 16px 60px;
        }

        .hPs {
            font-size: 24px;
            margin-top: 12px;
        }

        .servicesList {
            margin-top: 50px;
            gap: 8px;
        }

        .servicesItem {
            font-size: 18px;
            padding: 8px 16px;
        }

        .servicesItem::before {
            width: 8px;
            height: 8px;
        }
    }

    /* Маленькие мобильные (до 480px) */
    @media (max-width: 480px) {
        .content {
            padding: 80px 12px 80px;
        }

        .butt2{
        padding: 15px 20px;

        }

        .hPs {
            font-size: 18px;
        }

        .servicesList {
            display: none;
            margin-top: 40px;
            max-width: 100%;
        }

        .servicesItem {
            font-size: 16px;
            padding: 10px 16px;
            justify-content: center;
        }
    }
</style>
