---
// src/components/slide2.astro
import ReasonsSwiper from "./ReasonsSwiper.js";
---

<section id="slide02" class="slide">
    <div class="gr2">
        <div class="elGrid left">
            <div class="container2">
                <h2 class="h2">Почему <br /> выбирают <br /> нас</h2>
            </div>

            <div class="text">
                <p class="t25">
                    Мы предлагаем комплексные цифровые решения, разработанные с
                    учетом особенностей вашего бизнеса. Наши услуги помогают
                    ускорить рост компании, повысить эффективность процессов и
                    укрепить позиции на рынке.
                </p>
                <p class="t25">
                    Создавая индивидуальные стратегии и современные технологии,
                    мы обеспечиваем стабильное развитие и конкурентные
                    преимущества
                </p>
            </div>
        </div>

        <div class="container2 elGrid right">
            <h3 class="rTitle">
                Мы гарантия успешных <br />и инновационных решений!
            </h3>

            <!-- Десктопная версия -->
            <div class="rContent desktop-only">
                <div class="rItem">
                    <h4 class="rItemTitle">Креативность</h4>
                    <p class="rItemText">
                        Мы мыслим современно <br />и следим за всеми трендами в
                        дизайне и IT направлении
                    </p>
                    <div class="decor">
                        <span class="d1"></span>
                        <span class="d2"></span>
                    </div>
                </div>
                <div class="rItem">
                    <h4 class="rItemTitle">Компетентность</h4>
                    <p class="rItemText">
                        Создаем и интегрируем кроссплатформенные системы для
                        задач любой сложности
                    </p>
                    <div class="decor">
                        <span class="d1"></span>
                        <span class="d2"></span>
                    </div>
                </div>
                <div class="rItem">
                    <h4 class="rItemTitle">Надежность</h4>
                    <p class="rItemText">
                        Мы обеспечим надежную техническую поддержку Вашего сайта
                        и IT проекта
                    </p>
                    <div class="decor">
                        <span class="d1"></span>
                        <span class="d2"></span>
                    </div>
                </div>
                <div class="rItem">
                    <h4 class="rItemTitle">Эффективность</h4>
                    <p class="rItemText">
                        Мы создаем корпоративные ресурсы, которые работают на
                        Ваш имидж и бизнес-цели 24/7
                    </p>
                    <div class="decor">
                        <span class="d1"></span>
                        <span class="d2"></span>
                    </div>
                </div>
            </div>

            <!-- Мобильная версия с Swiper -->
            <div class="mobile-only">
                <ReasonsSwiper client:only="react" />
            </div>
        </div>
    </div>
</section>

<style>
    .decor {
        position: absolute;
        left: -11px;
        top: -11px;
        right: -11px;
        bottom: -11px;
        pointer-events: none;
    }

    .d1, .d2 {
        position: absolute;
        width: 100%;
        height: 100%;
        left: 0;
        top: 0;
        pointer-events: none;
    }

    .d1::after, .d1::before,
    .d2::before, .d2::after {
        content: "";
        display: block;
        width: 50px;
        height: 50px;
        position: absolute;
        border: 1px solid rgba(255, 255, 255, 0.4);
        pointer-events: none;
    }

    .d1::before { left: 0; top: 0; border-bottom: none; border-right: none; }
    .d2::before { bottom: 0; left: 0; border-top: none; border-right: none; }
    .d2::after  { right: 0; bottom: 0; border-top: none; border-left: none; }
    .d1::after  { right: 0; top: 0; border-bottom: none; border-left: none; }

    .rItem {
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        padding: 40px;
        gap: 20px;
        background: rgba(255, 255, 255, 0.07);
        backdrop-filter: blur(10px);
        border-radius: 10px;
        height: 100%;
        width: 100%;
    }

    .rItemTitle {
        font-family: var(--font-family);
        font-weight: 600;
        font-size: 25px;
        line-height: 100%;
        text-transform: uppercase;
        color: var(--belyy);
    }

    .rItemText {
        font-family: var(--second-family);
        font-weight: 500;
        font-size: 20px;
        line-height: 110%;
        color: var(--belyy);
        opacity: 0.8;
        max-width: 270px;
    }

    /* ==================== Swiper ==================== */
    .reasons-swiper-container {
        width: 100%;
        height: 100%;
        min-height: 420px;
    }

    .reasons-swiper {
        width: 100%;
        height: 100%;
    }

    .reasons-swiper .swiper-slide {
        height: auto;
        display: flex;
        align-items: stretch;
    }

    /* Пагинация */
    .reasons-swiper .swiper-pagination {
        position: relative;
        margin-top: 25px;
        bottom: auto !important;
    }

    /* Десктопный грид */
    .rContent {
        padding: 11px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 21px;
        height: 100%;
        margin-top: 40px;
    }

    .rTitle {
        font-family: var(--font-family);
        font-weight: 600;
        font-size: 30px;
        line-height: 100%;
        color: var(--belyy);
    }

    .text {
        height: 50%;
        display: flex;
        flex-direction: column;
        gap: 30px;
        border-top: 1px solid var(--seryy);
        padding: 45px 70px;
    }

    .elGrid {
        width: 100%;
        height: 100%;
    }

    .left {
        background: var(--svetlyy);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .right {
        background: url(/img/fon02.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        display: flex;
        flex-direction: column;
    }

    .mobile-only {
        display: none;
    }



    /* ==================== Адаптив ==================== */
    @media (max-width: 1024px) {
        .text { padding: 35px 40px; }
        .rTitle { font-size: 26px; }
        .rItem { padding: 30px; }
        .rItemTitle { font-size: 22px; }
        .rItemText { font-size: 18px; }
    }

    @media (max-width: 768px) {
        .gr2 {
            display: flex;
            flex-direction: column;
        }

        .left { min-height: auto; }
        .text {
            height: auto;
            padding: 30px 20px;
            gap: 10px;
            border: none;
        }
        .gr2{
            height: auto;
        }
        .right { padding-bottom: 100px !important; }
        #slide02 {
            padding-bottom: 0;
        }
        .right {
            padding-bottom: 30px;
        }
        .rTitle {
            font-size: 22px;
            text-align: center;
            margin-bottom: 20px;
        }

        .desktop-only { display: none; }
        .mobile-only { 
            display: block; 
            width: 100%;
            margin-top: 20px;
        }

        .reasons-swiper-container {
            min-height: 380px;
        }

        .rItem {
            padding: 32px 24px;
            min-height: fit-content;
        }

        .container2 { padding: 20px; }
    }

    @media (max-width: 480px) {

        .slide{
            padding-top: 60px;
        }
        .text { padding: 20px 16px; }
        .rTitle { font-size: 20px; }
        .container2 { padding: 16px; }
    }
</style>