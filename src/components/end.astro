<style>
    .right .h2 {
        color: var(--zelenyy-2-osnovnoy);
        width: 100%;
    }

    .linkBox{
        margin-top: auto;
    }
    .linkBox_item{
        color: var(--seryy);
    }

    .linkBox_item:hover {
        color: var(--zelenyy-2-osnovnoy);    
    }
    .right .ps {
        font-weight: 500;
        font-size: 40px;
        line-height: 110%;
        color: var(--belyy);
        text-align: start;
        width: 100%;
    }
    #end {
        background: url(/img/fon02.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
    }

    .tit {
        color: var(--belyy);
    }
    .gr2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100vh;
    }
    .qr_link {
        margin-top: 2vh;
        cursor: pointer;
    }
    .qr {
        width: 100%;
        max-width: 300px;
        height: auto;
    }

    .linkBox {
        display: flex;
        gap: 10px;
    }

    .post {
        font-family: var(--second-family);
        font-weight: 400;
        font-size: clamp(1rem, 0.885rem + 0.57vw, 1.25rem);
        line-height: 1.1;
        color: var(--svetlo-seryy);
        opacity: 0.5;
        transition: 300ms;
        margin-top: 1.7rem;
        max-width: 613px;
    }

    .post:hover {
        opacity: 1;
    }

    .decor {
        position: absolute;
        left: -11px;
        top: -11px;
        right: -11px;
        bottom: -11px;
        pointer-events: none;
    }

    .siniy2 {
        all: unset;
        color: var(--siniy);
    }

    .link {
        font-family: var(--second-family);
        font-weight: 500;
        font-size: 30px;
        line-height: 110%;
        color: var(--belyy);
        width: fit-content;

        display: flex;
        gap: 10px;
        align-items: center;
        justify-content: center;
    }

    .link:hover {
        color: var(--siniy);
    }

    .list {
        gap: 1rem;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

    .right {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 70px;
        padding-top: 200px;
    }

    .rTitle {
        font-family: var(--font-family);
        font-weight: 600;
        font-size: 30px;
        line-height: 100%;
        color: var(--belyy);
    }

    .text {
        display: flex;
        flex-direction: column;
        justify-content: end;
        gap: 30px;
        border-top: 1px solid var(--seryy);
        padding: 45px 70px;
    }

    .t30 {
        font-family: var(--second-family);
        font-weight: 500;
        line-height: 110%;
        color: var(--belyy);
    }

    .rContent {
        padding: 11px;
        display: grid;
        grid-template-columns: repeat(2, 0.8fr);
        grid-template-rows: repeat(2, 0.8fr);
        gap: 21px;
        height: 100%;
        margin-top: 40px;
    }

    .linkBox a {
        transition: 300ms;
    }

    .linkBox a:hover {
        transform: scale(1.1);
    }

    /* Адаптив */
    @media (max-width: 1024px) {
        .left {
            padding: 40px;
        }

        .text {
            padding: 30px 40px;
        }

        .right {
            padding: 40px;
        }
    }

    @media (max-width: 768px) {
        .gr2 {
            grid-template-columns: 1fr;
            height: auto;
            min-height: 100vh;
        }

        .left {
            padding: 80px 20px 40px;
            min-height: auto;
            gap: 20px;
        }

        .list {
            margin-bottom: 30px;
        }

        .but {
            width: 100%;
            text-align: center;
        }

        .text {
            padding: 30px 20px;
        }

        .right {
            padding: 40px 20px;
            min-height: auto;
        }

        .qr {
            max-width: 300px;
            margin: 0 auto;
        }

        .post {
            text-align: center;
            font-size: 12px;
            max-width: 100%;
        }
    }

    @media (max-width: 480px) {
        .left {
            padding: 90px 16px 30px;
        }

        .link {
            font-size: 16px;
        }

        .text {
            padding: 20px 16px;
        }

        .right {
            padding: 30px 16px;

            padding-bottom: 90px;
            align-items: center;
            text-align: center;
        }

        .linkBox img {
            width: 40px;
            height: 40px;
            justify-content: start;
        }

        .qr {
            max-width: 250px;
        }

        .post {
            font-size: 11px;
            margin-top: 20px;
        }
        .right .ps {
            text-align: center;
            width: 100%;
        }
        .linkBox {
            justify-content: start;
            margin-top: 20px;
        }

        .link svg{
            width: 20px;
            height: 20px    ;
        }

        
    }
</style>
