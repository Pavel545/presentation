---
import slides from "../data/data.json";
import { goToSlide } from "../lib/sliderController";
---

<div class="pagination">
    <div class="container">
        <div class="track">
            {
                slides.map((item, index) => (
                    <div  class=`item ${index==0 && "active"}`>
                        <div class="rect">
                            <div class="id">{item.id}</div>
                        </div>

                        <div class="preview">
                            <img src={item.img} alt={item.name} />
                            <span>{item.name}</span>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</div>

<style>
    .pagination {
        width: 100%;
        position: fixed;
        bottom: 0;
        z-index: 1000;
    }

    .track {
        display: grid;
        grid-template-columns: repeat(13, 1fr);
        gap: 5px;
        justify-content: center;

        padding: 30px 0 15px;
    }

    /* ================= ITEM ================= */

    .item {
        position: relative;
        width: 100%;
        height: 5px;
        cursor: pointer;
        transition: 300ms;
    }

    .item.active .rect {
        background: var(--zelenyy-3);
    }

    .rect {
        width: 100%;
        height: 100%;
        background: #ddd;
        border-radius: 6px;
        transition: all 0.3s ease;

        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ================= GROUP HOVER ================= */

    .track:hover .item {
        height: 20px;
    }

    /* ================= ID ================= */

    .id {
        /* position: absolute; */
        font-size: 12px;
        opacity: 0;
        transition: 0.3s;
    }

    .track:hover .id {
        opacity: 1;
    }

    /* ================= ACTIVE HOVER ================= */

    .item:hover .rect {
        background: var(--zelenyy-3);
    }

    .item:hover .id {
        opacity: 1;
    }

    /* ================= PREVIEW ================= */

    .preview {
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translate(-50%, 10px);
        width: 140px;
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        opacity: 0;
        pointer-events: none;
        transition: 0.3s;
    }

    .preview img {
        width: 100%;
        height: 80px;
        object-fit: cover;
    }

    .preview span {
        display: block;
        padding: 8px;
        font-size: 12px;
    }

    .item:hover .preview {
        opacity: 1;
        transform: translate(-50%, -10px);
    }
</style>
