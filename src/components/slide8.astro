<section id="slide08" class="slide">
    <div class="container2 cont">
        <h2 class="h2 tGradient">Разработка <br> лендинга</h2>

        <div class="content">
            <div class="left ">
                <div class="group">
                    <h3 class="t25 tit">Что мы проверим:</h3>

                    <p class="t20">
                        Быструю разработку продающих одностраничных сайтов
                        (лендингов) под ключ в трёх тарифных пакетах — от
                        экономичного старта до премиум-решения с максимальной
                        конверсией и современными технологиями
                    </p>
                </div>
                <div class="group">
                    <h3 class="t25 tit">Для чего это вам:</h3>

                    <p class="t20">
                        Получить эффективный инструмент продаж в минимальные
                        сроки для быстрого запуска продукта, проверки гипотезы
                        или запуска рекламных кампаний
                    </p>
                </div>
                <div class="group">
                    <h3 class="t25 tit">Результат:</h3>

                    <p class="t20">
                        Современный, быстрый и полностью адаптивный лендинг,
                        который круглосуточно собирает заявки, продаёт и
                        работает на рост вашего бизнеса
                    </p>
                </div>
            </div>

            <div class="right">
                <div
                    class="item active"
                    style="--colS:1; --colEnd:1; --rowS:1; --rowEnd:2;"
                >
                    <div class="group">
                        <h3 class="t30 tit">БИЗНЕС</h3>

                        <p class="t16 ps">
                            Когда нужен максимум продаж и скорости
                        </p>

                        <ul class="list">
                            <li>
                                {" Ультра-скорость загрузки (<2 сек)"}
                            </li>
                            <li>Экспертный контент для ИИ- поисковиков</li>
                            <li>Telegram Mini App + интеграция с CRM</li>
                        </ul>
                    </div>

                    <div class="group ">
                        <div class="group grup2">
                            <p class="t16 grey">Сроки:</p>
                            <span class="t20 siniy"> от 14 дней </span>
                        </div>
                        <div class="group grup2">
                            <p class="t16 grey">Стоимость:</p>
                            <span class="t20 siniy">95 000 ₽</span>
                        </div>
                    </div>
                </div>

                 <div
                    class="item"
                    style="--colS:2; --colEnd:1; --rowS:1; --rowEnd:1;"
                >
                    <div class="group">
                        <h3 class="t30 tit">ЭКОНОМ </h3>

                        <p class="t16 ps">
                            Идеально для самого дешёвого и быстрого старта
                        </p>

                        <ul class="list">
                            <li>
                               Базовая мобильная адаптация
                            </li>
                            <li>Продающий текст</li>
                            <li>Формы заказов</li>
                        </ul>
                    </div>

                    <div class="group row">
                        <div class="group grup2">
                            <p class="t16 grey">Сроки:</p>
                            <span class="t20 siniy">от 7 дней</span>
                        </div>
                        <div class="group grup2">
                            <p class="t16 grey">Стоимость:</p>
                            <span class="t20 siniy">30 000 ₽</span>
                        </div>
                    </div>
                </div>

                 <div
                    class="item"
                    style="--colS:2; --colEnd:1; --rowS:2; --rowEnd:1;"
                >
                    <div class="group">
                        <h3 class="t30 tit">СТАНДАРТ</h3>

                        <p class="t16 ps">
                            Отличное качество за разумные деньги
                        </p>

                        <ul class="list">
                            <li>
                            Проработанная мобильная версия
                            </li>
                            <li>UX-копирайтинг + анализ ЦА </li>
                            <li>Чат-бот + интеграции с соцсетями</li>
                        </ul>
                    </div>

                    <div class="group row">
                        <div class="group grup2">
                            <p class="t16 grey">Сроки:</p>
                            <span class="t20 siniy"> от 10 дней </span>
                        </div>
                        <div class="group grup2">
                            <p class="t16 grey">Стоимость:</p>
                            <span class="t20 siniy"> 55 000 ₽</span>
                        </div>
                    </div>
                </div>
                <div class="decor">
                    <img class="decorImg" src="/src/assets/decor2.svg" alt="Декор">
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .content {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        height: 100%;
    }

    .cont {
        height: 90%;
    }

    .grup2 {
        gap: 12px;
    }

    .row {
        flex-direction: row;
        gap: 70px;
    }

    .ps {
        font-family: var(--second-family);
        font-weight: 500;
        line-height: 1.3;
        color: var(--svetlo-seryy);
    }

    .left {
        margin-right: 30px;
        margin-top: 60px;
        display: flex;
        flex-direction: column;
        gap: 60px;
        max-width: 583px;
    }

    .right {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        gap: 12px;
        padding-top: 60px;
    }

    .decor {
        position: absolute;
        z-index: 0;
        width: 50%;
        bottom: 0;
        height: 100%;
        right: 0;
    }

    .decorImg {
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
    }

    .item {
        border-radius: var(--br);
        background: var(--belyy);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 20px;
        position: relative;
        z-index: 2;
        padding: 30px 25px;
        grid-column: var(--colS) / span var(--colEnd);
        grid-row: var(--rowS) / span var(--rowEnd);
    }

    .item.active {
        background: url(/fonActive.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
    }

    .item.active .tit {
        color: var(--zelenyy-2-osnovnoy);
    }

    .item.active .list {
        color: var(--belyy);
    }

    .item.active .grup2 span {
        color: var(--zelenyy-2-osnovnoy);
    }

    .item.active .grup2 p {
        color: var(--svetlo-seryy);
    }

    .list {
        padding-left: 20px;
        margin-top: 30px;
    }

    /* Адаптация для мобильных устройств */
    @media (max-width: 768px) {
        .cont {
            height: auto;
        }
        .slide {
            padding-top: 60px;
        }
        .content {
            grid-template-columns: 1fr !important;
            gap: 30px;
        }

        .left {
            margin-right: 0;
            margin-top: 30px;
            gap: 30px;
            max-width: 100%;
        }

        .right {
            grid-template-columns: 1fr !important;
            grid-template-rows: auto !important;
            gap: 15px;
            padding-top: 0;
        }

        .item {
            grid-column: auto !important;
            grid-row: auto !important;
            padding: 25px 20px;
            min-height: auto;
        }

        .item.active {
            order: -1; /* Поднимаем активный элемент наверх */
            flex-direction: column;
        }

        .row {
            flex-direction: column;
            gap: 15px;
        }

        .list {
            margin-top: 15px;
        }

        .list li {
            font-size: 15px;
            padding-bottom: 5px;
        }

        .decor {
            width: 100%;
            height: 50%;
            opacity: 0.4;
            bottom: auto;
            top: 50%;
            transform: translateY(-50%);
        }


        .grup2 {
            gap: 8px;
        }

        .ps {
            font-size: 14px;
        }

        h2 br {
            display: none;
        }
    }

    /* Для очень маленьких экранов */
    @media (max-width: 480px) {
        .left {
            margin-top: 20px;
            gap: 25px;
        }

        .right {
            gap: 12px;
        }

        .item {
            padding: 20px 15px;
        }

        .list {
            padding-left: 18px;
            margin-top: 12px;
        }

        .list li {
            font-size: 14px;
        }

      

   
        .decor {
            height: 40%;
            opacity: 0.3;
        }

        .group {
            gap: 10px;
        }

        .grup2 {
            flex-direction: row;
            justify-content: space-between;
            width: 100%;
        }
    }

    /* Для планшетов в портретной ориентации */
    @media (min-width: 769px) and (max-width: 1024px) {
        .content {
            grid-template-columns: 1fr 1fr !important;
            gap: 10px;
        }

        .left {
            margin-right: 20px;
            gap: 40px;
        }

        .right {
            grid-template-columns: 1fr !important;
            grid-template-rows: auto !important;
        }

        .item {
            grid-column: auto !important;
            grid-row: auto !important;
        }

        .row {
            gap: 30px;
        }
    }
</style>
