---
import slides from "../data/data.json";

import AIChatWrapper from "./chat/AIChatWrapper";
import "./logo.scss";
import Logo from "../assets/logoAnim.svg";
import MenuIcon from "../assets/menu.svg";
---

<header class="header" id="header">
    <div class="container">
        <div class="content">
            <!-- Десктоп логотип -->
            <div class="group row">
                <a href="/" class="logo boxLogo desktop-logo">
                    <Logo class="logoImg" id="logoImage" />
                </a>
                <AIChatWrapper
                    client:load
                    welcomeMessage="👋 Здравствуйте! Я AI ассистент. Чем могу помочь?"
                    suggestedQuestions={[
                        "Расскажите о продуктах",
                        "Какие у вас цены?",
                        "Как связаться с поддержкой?",
                    ]}
                />
            </div>

            <button class="menu" id="burger">
                <span class="menu-text">Меню</span>
                <MenuIcon class="menu-icon" />

                <svg
                    class="bac"
                    width="60"
                    height="60"
                    viewBox="0 0 60 60"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="14.4141"
                        y="44"
                        width="42"
                        height="2"
                        transform="rotate(-45 14.4141 44)"
                        fill="#282631"></rect>
                    <rect
                        x="15.4141"
                        y="14"
                        width="42"
                        height="2"
                        transform="rotate(45 15.4141 14)"
                        fill="#282631"></rect>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- OVERLAY -->
<div class="overlay" id="overlay"></div>

<!-- MENU PANEL -->
<aside class="sideMenu" id="sideMenu">
    <div class="menuHeader">
        <h2 class="menuTitle">Содержание</h2>
    </div>
    <div class="menuContent">
        {
            slides.map((item, index) => (
                <div class={`slide ${index == 0 ? "active" : ""}`}>
                    <span class="id">{item.id}</span>
                    <div class="title">
                        <span>{item.name}</span>
                    </div>
                </div>
            ))
        }
    </div>
</aside>

<style>
    .header {
        top: 40px;
        left: 0;
        position: fixed;
        width: 100%;
        z-index: 1001;
        transition: all 0.3s ease;
    }

    .content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
    }

    .boxLogo {
        display: block;
    }

    .imgLogo {
        height: 40px;
        width: auto;
        transition: all 0.3s ease;
    }

    .row {
        flex-direction: row;
        align-items: center;
        gap: 1vw;
        width: 90%;
    }

    /* ================= BURGER ================= */

    .menu {
        bottom: 10px;
        right: 0;
        border-radius: var(--br);
        background: transparent;
        border: none;
        cursor: pointer;
        transition: 500ms;
        animation: In 3s;
        transform: translateX(0);
        font-family: var(--font-family);
        font-weight: 500;
        font-size: 22px;
        line-height: 110%;
        color: var(--temnyy);
        display: flex;
        align-items: center;
        gap: 8px;
        /* min-width: 100px; */
        justify-content: flex-end;
    }

    .menu-icon {
        width: 45px;
        height: 45px;
        transition: transform 0.3s ease;
        z-index: 2;
        position: relative;
    }

    .menu-icon circle {
        fill: var(--zelenyy-3) !important;
        stroke-width: 4;
    }

    .menu-text {
        display: inline-block;
        position: relative;
        z-index: 2;
        font-size: 20px;
        font-weight: 500;
    }

    .menu:hover {
        transform: translateX(0);
    }

    .menu span {
        position: relative;
        z-index: 2;
        width: 0;
        overflow: hidden;
        transition: 300ms;
    }
    .menu:hover span {
        width: 100px;
    }

    .menu:hover {
        background: var(--zelenyy-3);
    }

    .menu:hover :global([data-it]) {
        fill: var(--zelenyy-3);
    }

    .menu :global([data-fon]) {
        fill: #282631;
    }

    .menu:hover :global([data-fon]) {
        fill: #282631;
    }

    .menu_decor {
        position: absolute;
        left: -40px;
        height: 100%;
        top: 0;
        z-index: 1;
    }
    .bac {
        display: none;
    }

    .menu.active .bac {
        display: block;
        cursor: pointer;
        fill: var(--siniy);
    }

    .menu.active .menu-text,
    .menu.active .menu-icon {
        display: none;
    }

    .menuTitle {
        height: 100px;
        display: flex;
        align-items: center;
        padding: 75px 40px;
        font-family: var(--font-family);
        font-weight: 700;
        font-size: 35px;
        line-height: 110%;
        color: var(--temnyy);
    }

    .menu.active {
        right: 21%;
        bottom: 45px;
        transform: translateX(0);
    }

    .menu.active .menu_decor {
        left: 151px;
        transform: rotate(180deg);
    }

    /* ================= OVERLAY ================= */

    .overlay {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(0px);
        background: rgba(0, 0, 0, 0);
        transition: 0.4s;
        pointer-events: none;
        z-index: 900;
    }

    .overlay.show {
        backdrop-filter: blur(2px);
        background: rgba(0, 0, 0, 0.2);
        pointer-events: all;
    }

    /* ================= MENU ================= */

    .sideMenu {
        position: fixed;
        top: 0;
        right: 0;
        width: 30%;
        height: 100vh;
        background: white;
        transform: translateX(100%);
        transition: transform 0.5s cubic-bezier(0.77, 0, 0.175, 1);
        z-index: 950;
        display: flex;
        flex-direction: column;
        padding-right: 45px;
        padding-bottom: 30px;
    }

    .sideMenu.open {
        transform: translateX(0);
    }

    .menuContent {
        padding: 30px 40px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        background: var(--svetlyy);
    }

    .menuContent::-webkit-scrollbar {
        width: 6px;
    }

    .menuContent::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }

    .menuContent::-webkit-scrollbar-track {
        background: transparent;
    }

    /* ================= SLIDES ================= */

    .slide {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: black;
        transition: 0.3s;
        position: relative;
        padding: 22px 30px;
        cursor: pointer;
    }
    .slide:hover {
        background: var(--zelenyy-1);
    }

    .slide.active {
        background: var(--zelenyy-3);
    }

    .slide:not(:last-child)::after {
        content: "";
        position: absolute;
        background: var(--temnyy);
        height: 0.5px;
        left: 0;
        bottom: 0;
        width: 100%;
        opacity: 0.7;
    }

    .imgWrap {
        overflow: hidden;
        width: 200px;
        height: 115px;
        border-radius: 3px;
    }

    .imgWrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }

    .slide:hover img {
        transform: scale(1.05);
    }

    .title {
        display: flex;
        gap: 10px;
        font-weight: 800;
        font-size: 16px;
        line-height: 110%;
        color: var(--temnyy);
        align-items: center;
    }

    .id {
        font-weight: 800;
        font-size: 16px;
        line-height: 110%;
        color: var(--siniy);
        margin-right: 20px;
    }

    /* ================= BODY LOCK ================= */

    body.lock {
        overflow: hidden;
        touch-action: none;
    }

    /* ================= АДАПТИВ ================= */

    @media (max-width: 768px) {
        .menu {
            display: none;
        }

        .header {
            top: 0;
            background: #0000001a;
            backdrop-filter: blur(15px);
            padding: 10px 0;
            /* Добавляем transition для плавного скрытия/показа */
            transition: transform 0.3s ease;
        }

        /* Класс для скрытия шапки */
        .header.hide {
            transform: translateY(-100%);
        }

        .desktop-logo {
            max-width: 140px;
            overflow: hidden;
        }

        .mobile-only {
            display: flex !important;
        }
        .row {
            width: 100%;
            justify-content: space-between;
        }
        .sideMenu {
            width: 100%;
            padding-right: 0;
        }

        .menuTitle {
            padding: 60px 20px 30px;
            font-size: 28px;
            height: auto;
        }

        .menuContent {
            padding: 20px;
            gap: 10px;
        }

        .slide {
            padding: 15px 20px;
        }

        .imgWrap {
            width: 120px;
            height: 80px;
        }

        .title {
            font-size: 14px;
        }

        .id {
            font-size: 14px;
        }
    }

    /* Маленькие мобилки */
    @media (max-width: 480px) {
        .menuTitle {
            padding: 90px 16px 20px;
            font-size: 24px;
        }

        .menu {
            bottom: -30px;
            height: max-content;
        }

        .menuContent {
            padding: 16px;
            padding-bottom: 50px;
            gap: 0;
        }

        .slide {
            padding: 12px 16px;
        }
        .sideMenu {
            background: var(--svetlyy);
        }
        .imgWrap {
            width: 100px;
            height: 70px;
        }
        .menu.go {
            bottom: 15px;
        }
    }

    /* Планшеты */
    @media (min-width: 769px) and (max-width: 1024px) {
        .sideMenu {
            width: 60%;
        }
    }

    @media (max-width: 768px) {
        .header {
            top: 0;
            background: #0000001a;
            backdrop-filter: blur(15px);
            padding: 10px 0;
            transition: transform 0.3s ease; /* ← убедитесь, что это здесь */
            will-change: transform; /* ← добавьте для производительности */
        }

        /* Класс для скрытия шапки */
        .header.hide {
            transform: translateY(-100%);
        }
    }
</style>

<script>
    // Smart header hide/show on scroll
    document.addEventListener("DOMContentLoaded", () => {

        // Инициализация ИИ-ассистента
        const aiBtn = document.getElementById("aiAssistantBtn");

        if (aiBtn) {
            aiBtn.addEventListener("click", () => {
                console.log("Открыть ИИ-ассистент");
            });
        }

        // Адаптация цвета бургера в зависимости от слайда
        const updateBurgerColor = () => {
            const burger = document.getElementById("burger");
            const isFirstSlide = window.sliderState?.current === 0;

            if (burger) {
                const spans = burger.querySelectorAll("span");
                const color = isFirstSlide ? "white" : "var(--temnyy)";

                if (!burger.classList.contains("active")) {
                    spans.forEach((span) => {
                        span.style.background = color;
                    });
                }
            }
        };

        // Слушаем изменения слайда
        window.addEventListener("slideChanged", updateBurgerColor);
    });
</script>
