        position: relative;
        overflow: hidden;
    }

    .right .composits {
        width: 100%;
        object-fit: contain;
    }

    /* Убедитесь, что gr2 — это grid */
    .gr2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        height: 100%;
    }

    /* ===== АДАПТАЦИЯ ===== */

    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
        .gr2 {
            gap: 24px;
        }

        .title {
            margin-bottom: 32px;
        }

        .left {
            gap: 28px;
        }

        .bottom {
            gap: 40px;
        }
    }

    /* Мобильные (до 768px) */
    @media (max-width: 768px) {
        .gr2 {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .left {
            gap: 24px;
        }

        .title {
            margin-bottom: 20px;
        }

        .bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
            margin-top: 24px;
        }

        .info {
            gap: 8px;
            flex-direction: row;
            align-items: baseline;
        }

        .right {
            min-height: 300px;
            order: -1; /* Картинка уходит наверх, если нужно */
        }

        .right .composits {
            max-height: 280px;
            width: auto;
            margin: 0 auto;
        }
    }

    /* Маленькие телефоны (до 480px) */
    @media (max-width: 480px) {
        .container2 {
            padding: 16px;
        }

        .title {
            margin-bottom: 16px;
        }

        .left {
            gap: 20px;
        }

        .ulSin {
            padding-left: 20px;
        }

        .ulSin li {
            margin-bottom: 8px;
        }

        .right {
            min-height: 220px;
        }

        .right .composits {
            max-height: 200px;
        }

        .bottom {
            width: 100%;
        }

        .info {
            width: 100%;
            justify-content: space-between;
        }
    }
</style>
