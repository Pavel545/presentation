<style>
    /* Базовые стили (десктоп) */
    .info {
        gap: 12px;
    }

    .title {
        margin-bottom: 50px;
    }

    .bottom {
        display: flex;
        gap: 90px;
        align-items: center;
        margin-top: auto;
    }

    .elGrid {
        width: 100%;
        height: 100%;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        gap: 40px;
    }

