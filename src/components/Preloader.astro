    ];

    class Preloader {
        private container: HTMLElement;
        private shapesContainer: HTMLElement;
        private bar: HTMLElement;
        private percent: HTMLElement;
        private progress: number = 0;
        private shapesElements: SVGElement[] = [];

        constructor() {
            this.container = document.getElementById("preloader")!;
            this.shapesContainer = document.getElementById("preloaderShapes")!;
            this.bar = document.getElementById("preloaderBar")!;
            this.percent = document.getElementById("preloaderPercent")!;

            this.init();
        }

        private init() {
            // Вставляем SVG
            shapes.forEach((shapeStr, i) => {
                const div = document.createElement("div");
                div.innerHTML = shapeStr;
                const svg = div.firstElementChild as SVGElement;
                svg.style.animationDelay = `${i * 0.1}s`;
                this.shapesContainer.appendChild(svg);
                this.shapesElements.push(svg);
            });

            this.startAnimation();
            this.trackLoading();
        }

        private startAnimation() {
            const radius = 80;

            // Анимация "дыхания" всей композиции
            const masterTimeline = gsap.timeline({
                repeat: -1,
                repeatDelay: 0.2,
            });

            this.shapesElements.forEach((shape, i) => {
                const angle = (i / this.shapesElements.length) * Math.PI * 2;

                // Начальная позиция - все в центре
                gsap.set(shape, {
                    x: 0,
                    y: 0,
                    scale: 0,
                    opacity: 0,
                    rotation: 0,
                });

                // Разлетаются по кругу
                masterTimeline.to(
                    shape,
                    {
                        x: Math.cos(angle) * radius,
                        y: Math.sin(angle) * radius,
                        scale: 1,
                        opacity: 0.8,
                        rotation: 180,
                        duration: 1.2,
                        ease: "elastic.out(1, 0.3)",
                    },
                    i * 0.05,
                );

                // Крутятся на месте
                masterTimeline.to(
                    shape,
                    {
                        rotation: "+=360",
                        duration: 3,
                        repeat: -1,
                        ease: "none",
                    },
                    ">",
                );

                // Пульсируют
                gsap.to(shape, {
                    scale: 1.3,
                    opacity: 1,
                    duration: 1,
                    repeat: -1,
                    yoyo: true,
                    ease: "sine.inOut",
                    delay: i * 0.1,
                });
            });

            // Собираются обратно в центр
            masterTimeline.to(
                this.shapesElements,
                {
                    x: 0,
                    y: 0,
                    scale: 0.8,
                    rotation: 0,
                    duration: 1,
                    ease: "back.in(2)",
                    stagger: 0.03,
                },
                "+=2",
            );
        }

        private trackLoading() {
            // Отслеживаем загрузку ресурсов
            const resources = [
                ...Array.from(document.images),
                ...Array.from(
                    document.querySelectorAll('link[rel="stylesheet"]'),
                ),
                ...Array.from(document.querySelectorAll("script")),
            ];

            let loaded = 0;
            const total = resources.length || 20; // fallback

            const updateProgress = () => {
                loaded++;
                this.progress = Math.min((loaded / total) * 100, 100);
                this.updateUI();
            };

            resources.forEach((res) => {
                if (res instanceof HTMLImageElement) {
                    if (res.complete) {
                        updateProgress();
                    } else {
                        res.addEventListener("load", updateProgress);
                        res.addEventListener("error", updateProgress);
                    }
                } else {
                    updateProgress(); // для скриптов и стилей считаем сразу
                }
            });

            // Fallback: если что-то пошло не так
            setTimeout(() => {
                const interval = setInterval(() => {
                    if (this.progress < 100) {
                        this.progress = Math.min(this.progress + 5, 100);
                        this.updateUI();

                        if (this.progress >= 100) {
                            clearInterval(interval);
                            setTimeout(() => this.hide(), 300);
                        }
                    }
                }, 100);
            }, 500);
        }

        private updateUI() {
            this.bar.style.width = `${this.progress}%`;
            this.percent.textContent = Math.round(this.progress).toString();
        }

        public hide() {
            // Останавливаем все анимации
            gsap.killTweensOf(this.shapesElements);

            // Красиво убираем прелоадер
            const tl = gsap.timeline({
                onComplete: () => {
                    this.container.remove();
                },
            });

            // Фигуры разлетаются
            this.shapesElements.forEach((shape, i) => {
                const angle = (i / this.shapesElements.length) * Math.PI * 2;
                tl.to(
                    shape,
                    {
                        x: Math.cos(angle) * 200,
                        y: Math.sin(angle) * 200,
                        scale: 0,
                        opacity: 0,
                        rotation: "+=180",
                        duration: 0.6,
                        ease: "power2.in",
                    },
                    0,
                );
            });

            // Затемнение и скрытие
            tl.to(
                this.container,
                {
                    opacity: 0,
                    duration: 0.4,
                    ease: "power2.in",
                },
                0.3,
            );
        }
    }

    // Ждем загрузки DOM
    document.addEventListener("DOMContentLoaded", () => {
        const preloader = new Preloader();

        // Когда всё загружено
        window.addEventListener("load", () => {
            preloader.hide();
        });
    });
</script>
