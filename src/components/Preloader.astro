---
// src/components/Preloader.astro
---

<div id="preloader" class="preloader">
    <div class="preloader__content">
        <div class="preloader__shapes" id="preloaderShapes">
            <!-- SVG будут вставлены через JS -->
        </div>
        <div class="preloader__progress">
            <div class="preloader__bar" id="preloaderBar"></div>
        </div>
        <div class="preloader__counter">
            <span id="preloaderPercent">0</span>%
        </div>
    </div>
</div>

<style is:global>
    .preloader {
        position: fixed;
        inset: 0;
        background: #0a0a0a;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

    .preloader__content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2vh;
        width: 300px;
    }

    .preloader__shapes {
        position: relative;
        width: 200px;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .preloader__shapes svg {
        position: absolute;
        width: 80px;
        height: 80px;
        opacity: 0;
        filter: blur(4px);
    }

    .preloader__progress {
        width: 100%;
        height: 2px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 1px;
        overflow: hidden;
    }

    .preloader__bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #a8d307, #e5ff8b, #bfef0a);
        border-radius: 1px;
        transition: width 0.1s ease;
    }

    .preloader__counter {
        color: #e5ff8b;
        font-family: monospace;
        font-size: 14px;
        letter-spacing: 2px;
    }

    /* Анимация ухода прелоадера */
    .preloader.hide {
        animation: preloaderHide 0.8s cubic-bezier(0.77, 0, 0.175, 1) forwards;
        pointer-events: none;
    }

    @keyframes preloaderHide {
        0% {
            opacity: 1;
            backdrop-filter: blur(0);
        }
        100% {
            opacity: 0;
            backdrop-filter: blur(10px);
            visibility: hidden;
        }
    }
</style>

<script>
    import { gsap } from "gsap";

    // Ваши SVG как строки (можно вынести в отдельный файл)
    const shapes = [
