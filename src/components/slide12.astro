<section id="slide12" class="slide">
    <div class="gr2">
        <div class="elGrid">
            <div class="container2 left">
                <div class="group title">
                    <h2 class="h2 tGradient">Внедрение ИИ</h2>
                    <p class="t20 grey">
                        Полный цикл внедрения искусственного интеллекта в ваш
                        бизнес под ключ
                    </p>
                </div>
                <div class="group">
                    <h3 class="t30 tit">Что предлагаем:</h3>
                    <ul class="ulSin">
                        <li>Аудит процессов и подбор оптимальных ИИ-решений</li>
                        <li>
                            Интеграция ИИ-моделей в сайт, приложение, CRM и
                            чат-боты
                        </li>
                        <li>Разработка кастомных нейросетей и автоматизаций</li>
                        <li>Обучение ИИ на ваших данных</li>
                        <li>
                            Автоматизация маркетинга, продаж, поддержки и
                            аналитики
                        </li>
                        <li>Полное тестирование, запуск и настройка</li>
                        <li>Дальнейшая поддержка и масштабирование</li>
                    </ul>
                </div>
                <div class="group">
                    <h3 class="t30 tit">Для чего это вам:</h3>
                    <p class="t20">
                        Автоматизировать рутинные задачи, персонализировать
                        клиентский опыт, повысить эффективность и получить
                        значительное конкурентное преимущество с помощью ИИ.
                    </p>
                </div>

                <div class="group">
                    <h3 class="t30 tit">Результат:</h3>
                    <p class="t20">
                        Работающий ИИ, который снижает затраты, увеличивает
                        продажи, улучшает сервис и даёт измеримый рост ключевых
                        показателей вашего бизнеса.Современное конкурентное
                        преимущество.
                    </p>
                </div>

                <div class="bottom">
                    <div class="group info">
                        <p class="t16 grey">Стоимость:</p>
                        <span class="t20 siniy"> от 50&nbsp;000&nbsp;₽</span>
                    </div>

                    <div class="group  fosBox">
                        <p
                            style="font-style: italic; color:var(--siniy)"
                            class="t20"
                        >
                            <span>
                                Описание функционала ИИ и варианты применения в
                                вашем бизнесе</span
                            >
                        </p>
                        <button
                            class="but"
                            data-popup
                            data-popup-title="Получите описание функционала ИИ и варианты применения в вашем бизнесе"
                        >
                            <b>Получить</b> бесплатно
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="elGrid right">
            <img
                class="composits"
                src="/img/12.png"
                alt="Разработка WebView, VK App и MAX App"
            />
        </div>
    </div>
</section>

<style>
    /* Базовые стили (десктоп) */
    .info {
        gap: 12px;
    }

    .title {
        margin-bottom: 0.5rem;
    }

    .bottom {
        display: flex;
        gap: 2rem;
        align-items: center;
        margin-top: auto;
    }

    .elGrid {
        width: 100%;
        height: 100%;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        gap: 2vh;
    }

    .right {
        background: url(/img/fon02.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .right .composits {
        width: 100%;
        object-fit: cover;
        object-position: right;
        height: 100%;
    }

    /* Убедитесь, что gr2 — это grid */
    .gr2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100%;
    }

    /* ===== АДАПТАЦИЯ ===== */

    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
        .title {
            margin-bottom: 32px;
        }

        .left {
            gap: 28px;
        }
    }

    /* Мобильные (до 768px) */
    @media (max-width: 768px) {
        .gr2 {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .left {
            gap: 24px;
        }

        .title {
            margin-bottom: 20px;
        }

        .bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            margin-top: 24px;
        }

        .info {
            gap: 8px;
            flex-direction: row;
            align-items: baseline;
        }
        .title {
            height: 80vh;
            background: url(/img/mob/11.png);
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            padding: 16px;
        }

        .mobIts {
            display: inline;
        }

        .title * {
            color: white !important;

            -webkit-text-fill-color: aliceblue;
        }

        .right {
            display: none;
        }
    }

    /* Маленькие телефоны (до 480px) */
    @media (max-width: 480px) {
        .container2 {
            padding: 0;
        }

        .group {
            padding: 1rem;
        }
        .title {
            margin-bottom: 16px;
            padding-top: 90px;
        }
        .left {
            gap: 10px;
        }

        .ulSin {
            padding-left: 20px;
        }

        .ulSin li {
            margin-bottom: 8px;
        }

        .bottom {
            width: 100%;
        }

        .info {
            width: 100%;
            justify-content: space-between;
        }

        .slide {
            padding-bottom: 60px;
        }
    }
</style>
