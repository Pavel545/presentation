---
import decorImage from "../assets/decor.svg";

---

<section id="slide07" class="slide">
    <div class="container2">
        <h2 class="h2 tGradient">Техническая <br> поддержка</h2>

        <div class="content">
            <div class="left">
                <h3 class="t25 tit">Что предлагаем:</h3>

                <div class="leftContent">
                    <div class="item">
                        <img
                            src="/icons/s7/1.svg"
                            alt="Круглосуточный мониторинг"
                        />
                        <p class="t20 itemT">Круглосуточный мониторинг</p>
                    </div>
                    <div class="item">
                        <img
                            src="/icons/s7/2.svg"
                            alt="Защита от DDoS-атак"
                        />
                        <p class="t20 itemT">Защита от DDoS-атак</p>
                    </div>
                    <div class="item">
                        <img
                            src="/icons/s7/3.svg"
                            alt="Защита от взломов"
                        />
                        <p class="t20 itemT">Защита от взломов</p>
                    </div>
                    <div class="item">
                        <img
                            src="/icons/s7/4.svg"
                            alt="Регулярные резервные копии"
                        />
                        <p class="t20 itemT">Регулярные резервные копии</p>
                    </div>
                    <div class="item">
                        <img src="/icons/s7/5.svg" alt="Обновления CMS и плагинов" />
                        <p class="t20 itemT">Обновления CMS и плагинов</p>
                    </div>
                    <div class="item">
                        <img
                            src="/icons/s7/4.svg"
                            alt="Оперативное устранение неполадок"
                        />
                        <p class="t20 itemT">Оперативное устранение неполадок</p>
                    </div>
                    <div class="item">
                        <img
                            src="/icons/s7/5.svg"
                            alt="Мониторинг производительности"
                        />
                        <p class="t20 itemT">Мониторинг производительности</p>
                    </div>
                    <div class="item">
                        <img
                            src="/icons/s7/5.svg"
                            alt="Техническая оптимизация и аудит"
                        />
                        <p class="t20 itemT">Техническая оптимизация и аудит</p>
                    </div>
                </div>

            </div>

            <div class="right">
                <div class="group">
                    <h3 class="t25 tit">Результат для вас</h3>

                <ul class="rightList">
                    <li>
                        Бесперебойная работа сайта 24/7
                    </li>
                    <li>
                     Максимальная защита данных и репутации
                    </li>
                    <li>
                     Быстрое решение всех технических вопросов без простоев
                    </li>
                    <li>Полное снятие технической головной боли с владельца сайта</li>
                </ul>
                </div>

                <div class="group">
                    <div class="group grup2">
                        <p class="t16 grey">Сроки:</p>
                        <span class="t20 siniy"> Постоянная поддержка </span>
                    </div>
                    <div class="group grup2">
                        <p class="t16 grey">Стоимость:</p>
                        <span class="t20 siniy"> от 5 000 ₽</span>
                    </div>
                </div>

                <div class="decor">
                    <img class="decorImg" src={decorImage.src} alt="">
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .content {
        display: grid;
        grid-template-columns: 2fr 1fr;
    }

    .grup2 {
        gap: 12px;
    }

    .ps {
        font-family: var(--second-family);
        font-style: italic;
        font-weight: 400;
        line-height: 1.2;
    }

    .left {
        margin-right: 30px;
        margin-top: 60px;
    }

    .right {
        padding: 70px 0 30px 30px;
        border-left: 1px solid var(--svetlo-seryy);

        display: flex;
        justify-content: space-between;
        flex-direction: column;
        gap: 40px;

        overflow: hidden;
    }

    .decor {
        position: absolute;
        z-index: 1;
        width: 50%;
        bottom: 0;
        height: 50%;
        right: 0;
    }

    .decorImg{
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
    }

    .rightList {
        padding-left: 20px;
    }
    .rightList li {
        list-style: decimal;
        padding-bottom: 10px;
    }

    .leftContent {
        margin: 30px 0;

        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: 1fr 1fr;
        gap: 10px;
    }

    .item {
        background: var(--belyy);
        border-radius: var(--br);

        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;

        gap: 20px;

        padding: 50px 40px;
    }

    .itemT {
        font-family: var(--second-family);
        font-weight: 700;
        line-height: 1.2;
        text-align: center;
    }
</style>
