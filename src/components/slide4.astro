<section id="slide04" class="slide">
    <div class="gr2">
        <div class="elGrid">
            <div class="container2 left">
                <div class="group title">
                    <h2 class="h2 tGradient">Умные чат-боты</h2>
                    <p class="t20 grey">
                        Полный цикл разработки умных чат-ботов под ключ
                    </p>
                </div>
                <div class="group">
                    <h3 class="t30">Что предлагаем:</h3>

                    <ul class="ulSin">
                        <li>
                            Продуманный дизайн диалогов и конверсионных
                            сценариев
                        </li>
                        <li>Интеграция с ИИ</li>
                        <li>
                            Разработка для MAX, Telegram, VK, сайта и других
                            платформ
                        </li>
                        <li>
                            Сложная бизнес-логика, интеграции с CRM, 1С,
                            платежами и базами данных
                        </li>
                        <li>Обучение бота на ваших данных</li>
                        <li>
                            Полное тестирование, запуск и настройка аналитики
                        </li>
                    </ul>
                </div>
                <div class="group">
                    <h3 class="t30">Для чего это вам:</h3>
                    <p class="t20">
                        Автоматизировать общение с клиентами 24/7, повысить
                        продажи, снизить нагрузку на менеджеров и значительно
                        улучшить качество сервиса.
                    </p>
                </div>
                <div class="group">
                    <h3 class="t30">Результат:</h3>
                    <p class="t20">
                        Умный чат-бот, который мгновенно отвечает, закрывает
                        сделки, собирает лиды и работает как профессиональный
                        сотрудник, давая рост конверсии и ощутимую экономию на
                        персонале.
                    </p>
                </div>

                <div class="bottom">
                    <div class="group info">
                        <p class="t16 grey">Сроки:</p>
                        <span class="t20 siniy"> от 2 дней </span>
                    </div>
                    <div class="group info">
                        <p class="t16 grey">Стоимость:</p>
                        <span class="t20 siniy"> от 20&nbsp;000&nbsp;₽</span>
                    </div>
                    <div class="group fosBox">
                        <p
                            style="font-style: italic; color:var(--siniy)"
                            class="t20"
                        >
                            <span>
                                Cценарий чат-бота, который приносит заявки</span
                            >
                        </p>
                        <button
                            class="but"
                            data-popup
                            data-popup-title="Cценарий чат-бота, который приносит заявки"
                        >
                            <b>Забрать</b> бесплатно
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="elGrid right">
            <img class="composits" src="/img/4.png" alt="Умные чат-боты" />
        </div>
    </div>
</section>

<style>
    /* Базовые стили (десктоп) */
    .info {
        gap: 12px;
    }

    .title {
        margin-bottom: 0.5rem;
    }

    .bottom {
        display: flex;
        gap: 2rem;
        align-items: center;
        margin-top: auto;
    }

    .elGrid {
        width: 100%;
        height: 100%;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        gap: 2rem;
    }

    .right {
        background: url(/img/fon02.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .right .composits {
        width: 100%;
        object-fit: contain;
    }

    .gr2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100%;
    }

    /* ===== АДАПТАЦИЯ ===== */

    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
        .gr2 {
        }

        .title {
            margin-bottom: 32px;
        }

        .left {
            gap: 28px;
        }
    }

    /* Мобильные (до 768px) */
    @media (max-width: 768px) {
        .gr2 {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .left {
            gap: 24px;
        }

        .title {
            margin-bottom: 20px;
        }

        .bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            margin-top: 24px;
        }

        .info {
            gap: 8px;
            flex-direction: row;
            align-items: baseline;
        }
        .title {
            height: 80vh;
            background: url(/img/mob/4.png);
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            padding: 16px;
        }

        .title * {
            color: white !important;

            -webkit-text-fill-color: aliceblue;
        }

        .right {
            display: none;
        }
    }

    /* Маленькие телефоны (до 480px) */
    @media (max-width: 480px) {
        .container2 {
            padding: 0;
        }

        .group {
            padding: 1.5vw;
        }
        .title {
            margin-bottom: 16px;
            padding-top: 90px;
        }
        .left {
            gap: 10px;
        }

        .ulSin {
            padding-left: 20px;
        }

        .ulSin li {
            margin-bottom: 8px;
        }

        .bottom {
            width: 100%;
        }

        .info {
            width: 100%;
            justify-content: space-between;
        }

        .slide {
            padding-bottom: 60px;
        }
    }
</style>
