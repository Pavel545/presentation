<style>
    /* Базовые стили (десктоп) */
    .info {
        gap: 12px;
    }

  

    .bottom {
        display: flex;
        gap: 2rem;
        align-items: center;
        margin-top: auto;
    }

    .g2{
        gap: 1vh !important;
    }

    .elGrid {
        width: 100%;
        height: 100%;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        gap: 3vh;
    }

    .right {
        background: url(/img/fon02.jpg);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .right .composits {
        width: 100%;
        object-fit: contain;
        object-position: right;
        height: 100%;
    }

    /* Убедитесь, что gr2 — это grid */
    .gr2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100%;
    }

   /* ===== АДАПТАЦИЯ ===== */

    /* Планшеты (768px - 1024px) */
    @media (max-width: 1024px) {
      

        .title {
            margin-bottom: 32px;
        }

        .left {
            gap: 28px;
        }

    }

    /* Мобильные (до 768px) */
    @media (max-width: 768px) {
        .gr2 {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .left {
            gap: 24px;
        }

        .title {
            margin-bottom: 20px;
        }

        .bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            margin-top: 24px;
        }

        .info {
            gap: 8px;
            flex-direction: row;
            align-items: baseline;
        }
        .title {
            height: 80vh;
            background: url(/img/mob/4.png);
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            padding: 16px;
        }

        .mobIts {
            display: inline;
        }

        .title * {
            color: white !important;

            -webkit-text-fill-color: aliceblue;
        }

        .right {
            display: none;
        }
    }

    /* Маленькие телефоны (до 480px) */
    @media (max-width: 480px) {
        .container2 {
            padding: 0;
        }

        .group {
            padding: 1rem;
        }
        .title {
            margin-bottom: 16px;
            padding-top: 90px;
        }
        .left {
            gap: 10px;
        }

        .ulSin {
            padding-left: 20px;
        }

        .ulSin li {
            margin-bottom: 8px;
        }

        .bottom {
            width: 100%;
        }

        .info {
            width: 100%;
            justify-content: space-between;
        }

        .slide {
            padding-bottom: 60px;
        }
    }
</style>
